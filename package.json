{
  "name": "caminhar",
  "version": "1.4.0",
  "description": "",
  "type": "module",
  "engines": {
    "node": "24.16.0",
    "npm": "11.17.0"
  },
  "scripts": {
    "check-env": "node scripts/check-env.js",
    "dev": "npm run check-env && next dev --turbo",
    "build": "npm run check-env && next build --turbo",
    "postbuild": "next-sitemap",
    "start": "npm run check-env && next start",
    "dev:clean": "npx kill-port 3000 && rm -rf .next && rm -f babel.config.js babel.config.cjs && npm run dev",
    "analyze": "next build --analyze",
    "lint": "eslint .",
    "lint:log": "eslint . 2>&1 | tee logs/eslint.log",
    "lint:fix": "eslint . --fix",
    "knip": "knip",
    "knip:watch": "knip --watch",
    "test": "jest",
    "test:log": "mkdir -p logs && jest 2>&1 | tee logs/tests-output.log",
    "warm-routes": "node scripts/warm-routes.js",
    "pretest:e2e": "node scripts/warm-routes.js",
    "test:e2e": "npx cypress run",
    "test:e2e:record": "npx cypress run --record --key 1c15e96c-3b79-4a4d-b2ec-7f0ffa209246",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:log": "mkdir -p logs && jest --coverage 2>&1 | tee logs/coverage-output.log",
    "test:coverage:watch": "jest --coverage --watch",
    "test:ci": "jest --ci --coverage --maxWorkers=1",
    "test:db:container": "jest --config jest.config.db.js",
    "test:db:container:coverage": "jest --config jest.config.db.js --coverage",
    "test:db": "jest tests/unit/lib/db.test.js",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "db:init": "node scripts/init-server.js",
    "db:status": "node scripts/check-db-status.js",
    "db:shell": "node scripts/db-shell.js",
    "db:reset": "node scripts/init-table.js posts && node scripts/init-table.js videos && node scripts/init-table.js musicas && node scripts/init-table.js dicas && npm run db:init",
    "db:reset:password": "node scripts/reset-password.js",
    "db:reset:safe": "npm run backup:create && npm run db:reset",
    "db:clean:test": "node scripts/clean-test-db.js",
    "backup:init": "node scripts/init-backup.js",
    "backup:create": "node scripts/create-backup.js",
    "backup:restore": "node scripts/restore-backup.js",
    "backup:logs": "node scripts/view-backup-logs.js",
    "seed:all": "node scripts/seed-all.js",
    "migrate": "node scripts/migrate.js",
    "migrate:status": "node scripts/migrate.js --status",
    "migrate:revert": "node scripts/migrate.js --revert",
    "cache:clear": "node scripts/clear-cache.js",
    "db:clear:musicas": "node scripts/clear-musicas.js",
    "db:clear": "node scripts/clear-db.js",
    "settings:update": "node scripts/utils/update-setting.js",
    "validate-schema": "node scripts/cli/validate-schema.js",
    "monitor:disk": "node scripts/monitor-disk-space.js",
    "clean:reports": "node scripts/clean-k6-reports.js",
    "clean:images": "node scripts/clean-orphaned-images.js",
    "test:load": "k6 run load-tests/functional/health-check.js",
    "test:load:auth": "k6 run -e ADMIN_USERNAME=${ADMIN_USERNAME:-admin} -e ADMIN_PASSWORD=${ADMIN_PASSWORD} load-tests/performance/authenticated-flow-test.js",
    "test:load:write": "k6 run -e ADMIN_USERNAME=${ADMIN_USERNAME:-admin} -e ADMIN_PASSWORD=${ADMIN_PASSWORD} load-tests/performance/create-post-flow.js",
    "test:load:write-and-clean": "npm run test:load:write && node scripts/clean-load-test-posts.js",
    "test:load:videos": "k6 run -e ADMIN_USERNAME=${ADMIN_USERNAME:-admin} -e ADMIN_PASSWORD=${ADMIN_PASSWORD} load-tests/performance/videos-load-test.js",
    "test:load:videos-crud": "k6 run -e ADMIN_USERNAME=${ADMIN_USERNAME:-admin} -e ADMIN_PASSWORD=${ADMIN_PASSWORD} load-tests/performance/videos-crud-test.js",
    "test:load:musicas-crud": "k6 run -e ADMIN_USERNAME=${ADMIN_USERNAME:-admin} -e ADMIN_PASSWORD=${ADMIN_PASSWORD} load-tests/performance/musicas-crud-test.js",
    "test:load:all": "node scripts/run-all-load-tests-sequentially.js",
    "test:load:all:log": "mkdir -p logs && node scripts/run-all-load-tests-sequentially.js 2>&1 | tee logs/load-tests.log",
    "test:load:orchestrator": "node scripts/run-all-load-tests-sequentially.js",
    "test:load:stress": "k6 run -e ADMIN_USERNAME=${ADMIN_USERNAME:-admin} -e ADMIN_PASSWORD=${ADMIN_PASSWORD} load-tests/performance/stress-test-combined.js",
    "test:load:search": "k6 run load-tests/functional/search-content-test.js",
    "test:load:ddos": "k6 run load-tests/security/ddos-search-test.js",
    "test:load:ratelimit": "k6 run load-tests/security/rate-limit-test.js",
    "test:load:cache": "k6 run load-tests/performance/cache-performance-test.js",
    "test:load:cache:headers": "k6 run load-tests/functional/cache-headers-test.js",
    "test:load:recovery": "k6 run load-tests/functional/recovery-test.js",
    "test:load:backup": "k6 run -e ADMIN_USERNAME=${ADMIN_USERNAME:-admin} -e ADMIN_PASSWORD=${ADMIN_PASSWORD} load-tests/functional/backup-verification-test.js",
    "test:load:videos:filter": "k6 run load-tests/performance/videos-filter-test.js",
    "test:load:videos:sort": "k6 run load-tests/performance/videos-sort-test.js",
    "test:load:musicas:search": "k6 run load-tests/performance/musicas-search-test.js",
    "test:load:musicas:filter": "k6 run load-tests/performance/musicas-filter-test.js",
    "test:load:posts:tags": "k6 run load-tests/functional/posts-tags-test.js",
    "test:load:posts:cursor": "k6 run load-tests/functional/posts-cursor-pagination-test.js",
    "test:load:musicas": "k6 run -e ADMIN_USERNAME=${ADMIN_USERNAME:-admin} -e ADMIN_PASSWORD=${ADMIN_PASSWORD} load-tests/performance/musicas-load-test.js",
    "test:load:login:negative": "k6 run load-tests/security/login-negative-test.js",
    "test:load:ip-spoofing": "k6 run load-tests/security/ip-spoofing-test.js",
    "test:load:musicas:pagination": "k6 run load-tests/performance/musicas-pagination-test.js",
    "test:load:musicas:sort": "k6 run load-tests/performance/musicas-sort-test.js",
    "test:load:videos:pagination": "k6 run load-tests/performance/videos-pagination-test.js",
    "test:load:videos:validation": "k6 run load-tests/functional/video-validation-test.js",
    "test:load:posts:pagination": "k6 run load-tests/performance/pagination-test.js",
    "security:check-sql": "node scripts/check-sql-injection.js",
    "security:check-sql:all": "node scripts/check-sql-injection.js --all",
    "test:load:safe": "bash scripts/run-load-tests.sh",
    "report:load": "ADMIN_USERNAME=${ADMIN_USERNAME:-admin} ADMIN_PASSWORD=${ADMIN_PASSWORD} node scripts/generate-load-report.js",
    "test:load:upload": "k6 run -e ADMIN_USERNAME=${ADMIN_USERNAME:-admin} -e ADMIN_PASSWORD=${ADMIN_PASSWORD} load-tests/functional/upload-flow-test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caminhar-deus/Caminhar.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/caminhar-deus/Caminhar/issues"
  },
  "homepage": "https://github.com/caminhar-deus/Caminhar#readme",
  "dependencies": {
    "@next/env": "^16.2.9",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "formidable": "^3.5.4",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.2.9",
    "pg": "^8.22.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-easy-crop": "^6.0.2",
    "react-hot-toast": "^2.6.0",
    "sharp": "^0.35.2",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@faker-js/faker": "^10.5.0",
    "@jest/globals": "^30.4.1",
    "@jest/reporters": "^30.4.1",
    "@testcontainers/postgresql": "^12.0.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "cypress": "^15.18.0",
    "eslint": "^10.6.0",
    "eslint-plugin-cypress": "^6.4.1",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-watch-typeahead": "^3.0.1",
    "knip": "^6.23.0",
    "next-sitemap": "^4.2.3",
    "node-mocks-http": "^1.17.2"
  },
  "overrides": {
    "tar": "^7.4.3",
    "glob": "^13.0.6",
    "minimatch": "^10.2.2",
    "postcss": "^8.5.10",
    "uuid": "^14.0.0",
    "whatwg-encoding": "^3.1.1"
  },
  "allowScripts": {
    "cpu-features@0.0.10": true,
    "protobufjs@7.6.4": true,
    "sharp@0.34.5": true,
    "ssh2@1.17.0": true,
    "unrs-resolver@1.12.2": true,
    "cypress@15.18.0": true
  }
}
