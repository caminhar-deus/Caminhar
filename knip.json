{
  "$schema": "./schema.knip.json",
  "paths": {
    "@/*": ["./*"]
  },
  "ignore": [
    "tests/**",
    "load-tests/**",
    "scripts/**",
    "examples/**",
    "styles/tokens/**",
    ".agents/**",
    "*.config.js",
    "jest.setup.js",
    "styleMock.js",
    "rate-limit-proxy.js"
  ],
  "ignoreBinaries": [
    "kill-port",
    "k6"
  ],
  "ignoreDependencies": [
    "@babel/preset-env",
    "@babel/preset-react",
    "@faker-js/faker",
    "@jest/reporters",
    "jest-watch-typeahead",
    "jsdom"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "duplicates": "off"
  }
}