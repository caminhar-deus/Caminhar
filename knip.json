{
  "$schema": "./schema.knip.json",
  "paths": {
    "@/*": ["./*"]
  },
  "ignore": [
    "tests/**",
    "load-tests/**",
    "scripts/**",
    "examples/**",
    ".agents/**",
    "*.config.js",
    "jest.setup.js"
  ],
  "ignoreBinaries": [],
  "ignoreDependencies": [
    "@babel/preset-env",
    "@babel/preset-react",
    "@faker-js/faker",
    "@jest/reporters",
    "babel-jest",
    "jest-watch-typeahead",
    "jsdom"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "duplicates": "off"
  }
}